{
    "name" : "vpg/slingshot",
    "description" : "ES Migration tool based on Scann/Scroll + bulk",
    "license" : "proprietary",
    "type" : "library",
    "repositories": {
        "VPG_ElasticSearch": {
            "type": "git",
            "url": "https://gitlab.vpg.tech/dev/legacy/services/elasticsearch-php"
        }
    },
    "require" : {
        "vpg/elasticsearch" : "6.7.*",
        "monolog/monolog" : "~1.4"
    },
    "require-dev": {
        "phpunit/phpunit": "4.0.*"
    },
    "autoload": {
        "psr-4": {
            "vpg\\slingshot\\": "library"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "vpg\\slingshot\\Tests\\": "tests"
        }
    }
}
